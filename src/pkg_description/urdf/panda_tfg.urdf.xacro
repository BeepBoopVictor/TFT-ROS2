<?xml version="1.0"?>
<robot name="panda_tfg" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ========================================================= -->
  <!-- Args globales                                             -->
  <!-- ========================================================= -->

  <xacro:arg name="robot_name" default="panda"/>
  <xacro:arg name="arm_id" default="panda"/>
  <xacro:arg name="prefix" default="panda_"/>

  <!-- Modo de uso -->
  <xacro:arg name="use_fake_hardware" default="false"/>
  <xacro:arg name="use_gazebo" default="true"/>
  <xacro:arg name="use_ros2_control" default="true"/>
  <xacro:arg name="use_gripper" default="true"/>

  <!-- Mundo / TF -->
  <xacro:arg name="world_frame" default="world"/>
  <xacro:arg name="base_frame" default="panda_link0"/>

  <!-- Pose inicial del robot respecto al mundo -->
  <xacro:arg name="xyz" default="0 0 0"/>
  <xacro:arg name="rpy" default="0 0 0"/>

  <!-- ========================================================= -->
  <!-- Includes propios                                          -->
  <!-- ========================================================= -->

  <xacro:include filename="$(find pkg_description)/urdf/materials.xacro"/>
  <xacro:include filename="$(find pkg_description)/urdf/panda_tfg.scene_frames.xacro"/>
  <xacro:include filename="$(find pkg_description)/urdf/panda_tfg.gazebo.xacro"/>
  <xacro:include filename="$(find pkg_description)/urdf/panda_tfg.ros2_control.xacro"/>

  <!-- ========================================================= -->
  <!-- Include del Panda oficial                                 -->
  <!-- ========================================================= -->
  <!--
    Este paquete no redefine el Panda. Usa franka_description como fuente.
    Si el path exacto cambia en tu instalación, compruébalo con:

      ros2 pkg prefix franka_description
      find $(ros2 pkg prefix franka_description)/share/franka_description -name "*.xacro"

    En la siguiente fase ajustaremos este include a tu instalación exacta.
  -->

  <xacro:include filename="$(find franka_description)/robots/panda/panda.urdf.xacro"/>

  <!-- ========================================================= -->
  <!-- Mundo y base fija                                         -->
  <!-- ========================================================= -->

  <link name="$(arg world_frame)"/>

  <joint name="$(arg world_frame)_to_$(arg base_frame)" type="fixed">
    <parent link="$(arg world_frame)"/>
    <child link="$(arg base_frame)"/>
    <origin xyz="$(arg xyz)" rpy="$(arg rpy)"/>
  </joint>

  <!-- ========================================================= -->
  <!-- Robot Panda oficial                                       -->
  <!-- ========================================================= -->
  <!--
    OJO:
    La macro exacta puede variar según la versión de franka_description.
    Lo normal en franka_description moderno es que exista una macro de robot
    Panda o FR3 parametrizable.

    En cuanto tengas el repo instalado, valida nombres con:

      grep -R "macro name" $(ros2 pkg prefix franka_description)/share/franka_description/robots -n

    Si la macro se llama distinto, solo cambia este bloque.
  -->

  <xacro:panda_robot
    arm_id="$(arg arm_id)"
    hand="$(arg use_gripper)"
    gazebo="$(arg use_gazebo)"
    ros2_control="$(arg use_ros2_control)"
  />

  <!-- ========================================================= -->
  <!-- Frames semánticos del TFG                                 -->
  <!-- ========================================================= -->

  <xacro:panda_tfg_scene_frames
    world_frame="$(arg world_frame)"
    base_frame="$(arg base_frame)"
    prefix="$(arg prefix)"
  />

  <!-- ========================================================= -->
  <!-- Gazebo extras                                             -->
  <!-- ========================================================= -->

  <xacro:if value="$(arg use_gazebo)">
    <xacro:panda_tfg_gazebo
      robot_name="$(arg robot_name)"
      prefix="$(arg prefix)"
    />
  </xacro:if>

  <!-- ========================================================= -->
  <!-- ros2_control                                              -->
  <!-- ========================================================= -->

  <xacro:if value="$(arg use_ros2_control)">
    <xacro:panda_tfg_ros2_control
      robot_name="$(arg robot_name)"
      prefix="$(arg prefix)"
      use_fake_hardware="$(arg use_fake_hardware)"
    />
  </xacro:if>

</robot>